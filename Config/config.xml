<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://thelia.net/schema/dic/config"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://thelia.net/schema/dic/config
                            http://thelia.net/schema/dic/config/thelia-module.xsd">

    <loops>
        <loop name="cawl_transaction" class="CawlPayment\Loop\CawlTransactionLoop" />
        <loop name="cawl_payment_method" class="CawlPayment\Loop\PaymentMethodLoop" />
    </loops>

    <forms>
        <form name="cawlpayment.configuration" class="CawlPayment\Form\ConfigurationForm" />
    </forms>

    <!-- Hooks Thelia - nécessitent des tags spécifiques non gérés par autoconfigure -->
    <hooks>
        <hook id="cawlpayment.hook.admin" class="CawlPayment\Hook\AdminHook">
            <argument type="service" id="CawlPayment\Service\CsrfTokenService"/>
            <tag name="hook.event_listener" event="module.configuration" type="back" method="onModuleConfiguration" />
        </hook>
        <hook id="cawlpayment.hook.front" class="CawlPayment\Hook\FrontHook">
            <tag name="hook.event_listener" event="order-invoice.payment-extra" type="front" method="onPaymentExtra" />
        </hook>
    </hooks>

</config>
